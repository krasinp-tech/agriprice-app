# AgriPrice backend environment template
# Copy this file to server/.env and replace placeholders with real values.

NODE_ENV=development
PORT=5000

# PostgreSQL / Supabase
DATABASE_URL=postgresql://username:password@host:port/database
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
OTP_MOCK=false

# Firebase client configuration
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# Firebase Admin: use either the JSON value or a runtime file path.
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Comma-separated extra web origins. Native/local defaults are built into the server.
CORS_ORIGIN=

# Uploads and payments
UPLOAD_MODE=supabase-storage
EASYSLIP_API_KEY=your-easyslip-api-key
PROMPTPAY_MSISDN=0900000000
PRO_PLAN_PRICE=499

# Automatic booking completion
BOOKING_AUTO_SUCCESS_DELAY_MIN=5
BOOKING_AUTO_SUCCESS_SCAN_SEC=60
BOOKING_AUTO_SUCCESS_DEBUG=true
